<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".MogiGoiApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MogiGoi">

        <!-- Home -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Level Selection -->
        <activity
            android:name=".ui.level.LevelActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"/>

        <!-- Lesson List -->
        <activity
            android:name=".ui.lesson.LessonListActivity"
            android:exported="false"
            android:parentActivityName=".ui.level.LevelActivity"/>

        <!-- Learning Mode Selection -->
        <activity
            android:name=".ui.mode.LearningModeActivity"
            android:exported="false"
            android:parentActivityName=".ui.lesson.LessonListActivity"/>

        <!-- Flashcard -->
        <activity
            android:name=".ui.flashcard.FlashCardActivity"
            android:exported="false"
            android:parentActivityName=".ui.mode.LearningModeActivity"/>

        <!-- Quiz -->
        <activity
            android:name=".ui.quiz.QuizActivity"
            android:exported="false"
            android:parentActivityName=".ui.mode.LearningModeActivity"/>

        <!-- Result -->
        <activity
            android:name=".ui.result.ResultActivity"
            android:exported="false"
            android:parentActivityName=".ui.quiz.QuizActivity"/>

    </application>

</manifest>